# Supabase → Connect → Session pooler → URI (required on IPv4 networks)
# Direct db.*.supabase.co is IPv6-only — do not use unless you have IPv4 add-on.

DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# Private admin login: http://localhost:3000/sfic/manage (not linked from public site)
ADMIN_PASSWORD="your-strong-admin-password"
ADMIN_EMAIL="admin@sfic.edu"
# Optional: separate secret for signed admin cookies (defaults to ADMIN_PASSWORD)
# ADMIN_SESSION_SECRET="long-random-string"

# --- Optional: split admin vs public on Vercel (hostname only, no https://) ---
# ADMIN_HOST=admin-your-project.vercel.app
# PUBLIC_HOST=your-project.vercel.app
# NEXT_PUBLIC_PUBLIC_SITE_URL=https://your-project.vercel.app
